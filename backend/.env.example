# Trendy Backend Environment Variables Example
# Replace these values with your actual deployment coordinates.

PORT=5000

# MongoDB - Use MongoDB Atlas free tier (M0) or local MongoDB
# Get your free cluster at: https://cloud.mongodb.com
# Example Atlas Connection String: mongodb+srv://username:password@cluster.mongodb.net/trendy-ecommerce?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/trendy-ecommerce

# JWT settings
JWT_SECRET=trendy_super_secret_jwt_key_2026_change_in_production
JWT_EXPIRE=7d

# Cookie duration in days
COOKIE_EXPIRE=7

# Client Origin for CORS
CLIENT_URL=http://localhost:5173

# Node Environment
NODE_ENV=development
