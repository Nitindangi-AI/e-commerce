# InsForge / Supabase backend
VITE_INSFORGE_URL=https://your-project.us-east.insforge.app
INSFORGE_URL=https://your-project.us-east.insforge.app
VITE_INSFORGE_ANON_KEY=your_anon_key_here
INSFORGE_ANON_KEY=your_anon_key_here

# API base URL (used by Node scripts and frontend)
VITE_API_BASE_URL=http://localhost:5000

# App name
VITE_APP_NAME=Trendy

# Razorpay (frontend key only — secret key goes in backend/.env)
VITE_RAZORPAY_KEY_ID=your_razorpay_key

# Test / seed account credentials
# Used by verify-ecommerce-flows.js, verify-production-auth.js, and Playwright specs.
# NEVER use production credentials here.
TEST_CUSTOMER_EMAIL=user1@trendy.com
TEST_CUSTOMER_PASSWORD=your_test_customer_password
TEST_VENDOR_EMAIL=seller1@trendy.com
TEST_VENDOR_PASSWORD=your_test_vendor_password
TEST_ADMIN_EMAIL=admin@trendy.com
TEST_ADMIN_PASSWORD=your_test_admin_password

# Sentry DSN
VITE_SENTRY_DSN=https://your-sentry-key@o0.ingest.sentry.io/0
